# ============================================================================
# Web Search Extension — API Keys
# ============================================================================
#
# Скопируйте этот файл в .env и заполните вашими API ключами:
# cp .env.example .env
#
# Или добавьте переменные окружения в ~/.zshrc:
# export EXA_API_KEY="your-key-here"
# export TAVILY_API_KEY="your-key-here"
# export PERPLEXITY_API_KEY="your-key-here"
#
# ============================================================================

# Exa API (рекомендуется для универсального поиска)
# Получите ключ: https://dashboard.exa.ai/api-keys
# Бесплатно: $10 кредитов после регистрации
EXA_API_KEY=

# Tavily API (оптимизирован для AI агентов)
# Получите ключ: https://app.tavily.com/
# Бесплатно: 1000 запросов/месяц
TAVILY_API_KEY=

# Perplexity API (лучшее качество, особенно для новостей)
# Получите ключ: https://www.perplexity.ai/settings/api
# Платно: от $5
PERPLEXITY_API_KEY=

# ============================================================================
# Опциональные настройки
# ============================================================================

# Использовать ли Ollama для трансформации запросов (экспериментально)
# Требует установленного Ollama: https://ollama.ai
# USE_OLLAMA=true

# Модель Ollama для трансформации (по умолчанию: llama3.2:1b)
# OLLAMA_MODEL=llama3.2:1b

# URL Ollama сервера (по умолчанию: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434
